<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/rootLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_screen_gradient"
    android:clipToPadding="false"
    android:fillViewport="true"
    android:overScrollMode="never"
    android:paddingStart="22dp"
    android:paddingTop="18dp"
    android:paddingEnd="22dp"
    android:paddingBottom="18dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <LinearLayout
            android:id="@+id/headerContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/logoTextView"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@drawable/bg_logo"
                android:fontFamily="@font/plus_jakarta_sans_extrabold"
                android:gravity="center"
                android:text="S+"
                android:textColor="#FFFFFF"
                android:textSize="18sp" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/appTitleTextView"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/plus_jakarta_sans_extrabold"
                    android:text="SehatYuk"
                    android:textColor="#142321"
                    android:textSize="30sp" />

                <TextView
                    android:id="@+id/appSubtitleTextView"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/plus_jakarta_sans_regular"
                    android:text="Klinik digital personal"
                    android:textColor="#63736F"
                    android:textSize="14sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/singleActivityChipTextView"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_chip"
                android:fontFamily="@font/plus_jakarta_sans_semibold"
                android:text="Single Activity"
                android:textColor="#196247"
                android:textSize="12sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/heroDescriptionTextView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:fontFamily="@font/plus_jakarta_sans_regular"
            android:lineSpacingExtra="4dp"
            android:text="Pantau BMI dan kebutuhan energi basal dari satu halaman pemeriksaan yang ringkas, rapi, dan aman dari input kosong."
            android:textColor="#63736F"
            android:textSize="16sp" />

        <LinearLayout
            android:id="@+id/formCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:background="@drawable/bg_card"
            android:elevation="3dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/formTitleTextView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="@font/plus_jakarta_sans_bold"
                android:text="Data pemeriksaan"
                android:textColor="#142321"
                android:textSize="22sp" />

            <TextView
                android:id="@+id/formSubtitleTextView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:fontFamily="@font/plus_jakarta_sans_regular"
                android:lineSpacingExtra="3dp"
                android:text="Isi data dasar pasien sebelum menghitung indikator kesehatan."
                android:textColor="#63736F"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/nameLabelTextView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:fontFamily="@font/plus_jakarta_sans_semibold"
                android:text="Nama"
                android:textColor="#142321"
                android:textSize="13sp" />

            <EditText
                android:id="@+id/nameEditText"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_input"
                android:fontFamily="@font/plus_jakarta_sans_regular"
                android:hint="Contoh: Aulia Rahman"
                android:imeOptions="actionNext"
                android:inputType="textPersonName"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:singleLine="true"
                android:textColor="#142321"
                android:textColorHint="#8D9A96"
                android:textSize="15sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="6dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/weightLabelTextView"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/plus_jakarta_sans_semibold"
                        android:text="Berat badan"
                        android:textColor="#142321"
                        android:textSize="13sp" />

                    <EditText
                        android:id="@+id/weightEditText"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/bg_input"
                        android:fontFamily="@font/plus_jakarta_sans_regular"
                        android:hint="70 kg"
                        android:imeOptions="actionNext"
                        android:inputType="numberDecimal"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:singleLine="true"
                        android:textColor="#142321"
                        android:textColorHint="#8D9A96"
                        android:textSize="15sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/heightLabelTextView"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/plus_jakarta_sans_semibold"
                        android:text="Tinggi badan"
                        android:textColor="#142321"
                        android:textSize="13sp" />

                    <EditText
                        android:id="@+id/heightEditText"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/bg_input"
                        android:fontFamily="@font/plus_jakarta_sans_regular"
                        android:hint="170 cm"
                        android:imeOptions="actionNext"
                        android:inputType="numberDecimal"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:singleLine="true"
                        android:textColor="#142321"
                        android:textColorHint="#8D9A96"
                        android:textSize="15sp" />
                </LinearLayout>
            </LinearLayout>

            <TextView
                android:id="@+id/ageLabelTextView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:fontFamily="@font/plus_jakarta_sans_semibold"
                android:text="Umur"
                android:textColor="#142321"
                android:textSize="13sp" />

            <EditText
                android:id="@+id/ageEditText"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_input"
                android:fontFamily="@font/plus_jakarta_sans_regular"
                android:hint="20 tahun"
                android:imeOptions="actionDone"
                android:inputType="number"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:singleLine="true"
                android:textColor="#142321"
                android:textColorHint="#8D9A96"
                android:textSize="15sp" />

            <LinearLayout
                android:id="@+id/validationContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_warning"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:visibility="gone">

                <TextView
                    android:id="@+id/warningBadgeTextView"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:background="@drawable/bg_warning_badge"
                    android:fontFamily="@font/plus_jakarta_sans_bold"
                    android:gravity="center"
                    android:text="!"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/validationMessageTextView"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:layout_weight="1"
                    android:fontFamily="@font/plus_jakarta_sans_regular"
                    android:lineSpacingExtra="2dp"
                    android:textColor="#7A4B09"
                    android:textSize="13sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/actionContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/calculateBmiButton"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_marginEnd="6dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_button_primary"
                    android:fontFamily="@font/plus_jakarta_sans_bold"
                    android:stateListAnimator="@null"
                    android:text="Hitung BMI"
                    android:textAllCaps="false"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp" />

                <Button
                    android:id="@+id/calculateBmrButton"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_marginStart="6dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_button_secondary"
                    android:fontFamily="@font/plus_jakarta_sans_bold"
                    android:stateListAnimator="@null"
                    android:text="Hitung BMR"
                    android:textAllCaps="false"
                    android:textColor="#0D7A5F"
                    android:textSize="14sp" />
            </LinearLayout>

            <Button
                android:id="@+id/resetButton"
                android:layout_width="wrap_content"
                android:layout_height="44dp"
                android:layout_gravity="end"
                android:layout_marginTop="6dp"
                android:background="@android:color/transparent"
                android:fontFamily="@font/plus_jakarta_sans_semibold"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:stateListAnimator="@null"
                android:text="Reset form"
                android:textAllCaps="false"
                android:textColor="#0D7A5F"
                android:textSize="13sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/resultCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:background="@drawable/bg_dark_card"
            android:elevation="4dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/resultTitleTextView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="@font/plus_jakarta_sans_bold"
                android:text="Hasil pemeriksaan akan muncul di sini"
                android:textColor="#FFFFFF"
                android:textSize="18sp" />

            <TextView
                android:id="@+id/resultSummaryTextView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:fontFamily="@font/plus_jakarta_sans_regular"
                android:lineSpacingExtra="3dp"
                android:text="Tekan salah satu tombol kalkulasi setelah semua kolom terisi."
                android:textColor="#C4D7D1"
                android:textSize="14sp" />

            <ProgressBar
                android:id="@+id/healthProgressBar"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="8dp"
                android:layout_marginTop="16dp"
                android:max="100"
                android:progress="0"
                android:progressDrawable="@drawable/progress_health" />

            <LinearLayout
                android:id="@+id/resultTileContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="horizontal">

                <LinearLayout
                    android:id="@+id/resultMetricTile"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_marginEnd="6dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_metric_tile"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/resultValueTextView"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/plus_jakarta_sans_extrabold"
                        android:text="--"
                        android:textColor="#FFFFFF"
                        android:textSize="38sp" />

                    <TextView
                        android:id="@+id/resultUnitTextView"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/plus_jakarta_sans_bold"
                        android:text="BMI / BMR"
                        android:textColor="#A8C1BA"
                        android:textSize="13sp" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/resultInsightTile"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_marginStart="6dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_label_tile"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/resultCategoryTextView"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/plus_jakarta_sans_bold"
                        android:text="Menunggu data"
                        android:textColor="#8DD7BE"
                        android:textSize="15sp" />

                    <TextView
                        android:id="@+id/resultInsightTextView"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:fontFamily="@font/plus_jakarta_sans_regular"
                        android:lineSpacingExtra="3dp"
                        android:text="Validasi input menjaga aplikasi tetap stabil saat form kosong."
                        android:textColor="#E2ECE8"
                        android:textSize="12sp" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</ScrollView>
